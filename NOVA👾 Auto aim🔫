-- Core Logic
local function visible(part)
    local origin = Camera.CFrame.Position
    local dir = part.Position - origin
    local param = RaycastParams.new()
    param.FilterDescendantsInstances = {LP.Character}
    param.FilterType = Enum.RaycastFilterType.Blacklist
    local ray = workspace:Raycast(origin, dir, param)
    return ray and ray.Instance:IsDescendantOf(part.Parent) or false
end

local function isSameTeam(player)
    if not TeamCheck then return false end
    return player.Team == LP.Team
end

local function getTarget()
    local closest = nil
    local dist = FOV
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LP and not isSameTeam(v) and v.Character and v.Character:FindFirstChild(AimPart) then
            local part = v.Character[AimPart]
            local pos, vis = Camera:WorldToViewportPoint(part.Position)
            if vis and visible(part) then
                local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if mag < dist then
                    dist = mag
                    closest = v
                end
            end
        end
    end
    return closest
end

local function drawVisuals(player, color)
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    if not hrp or not head then return end

    local headPos, headVis = Camera:WorldToViewportPoint(head.Position)
    local rootPos, rootVis = Camera:WorldToViewportPoint(hrp.Position)

    if headVis or rootVis then
        if ESP_Enabled then
            local height = math.abs(headPos.Y - rootPos.Y) * 2
            local width = height / 1.5
            local topLeft = Vector2.new(rootPos.X - width/2, rootPos.Y - height/2)

            local box = espDrawings[player.Name .. "_Box"] or Drawing.new("Square")
            box.Thickness = 2
            box.Filled = false
            box.Visible = true
            box.Color = color
            box.Size = Vector2.new(width, height)
            box.Position = topLeft
            espDrawings[player.Name .. "_Box"] = box

            local name = espDrawings[player.Name .. "_Name"] or Drawing.new("Text")
            name.Size = 14
            name.Outline = true
            name.Center = true
            name.Visible = true
            name.Color = color
            name.Text = player.Name
            name.Position = Vector2.new(rootPos.X, topLeft.Y - 15)
            espDrawings[player.Name .. "_Name"] = name
        end

        if Tracer_Enabled then
            local tracer = espDrawings[player.Name .. "_Tracer"] or Drawing.new("Line")
            tracer.Thickness = 2
            tracer.Color = color
            tracer.Transparency = 1
            tracer.Visible = true
            tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
            tracer.To = Vector2.new(rootPos.X, rootPos.Y)
            espDrawings[player.Name .. "_Tracer"] = tracer
        end

        if DistanceESP_Enabled then
            local dist = math.floor((LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") and 
                        (LP.Character.HumanoidRootPart.Position - hrp.Position).Magnitude or 0) + 0.5)
            
            local dText = espDrawings[player.Name .. "_Distance"] or Drawing.new("Text")
            dText.Size = 12
            dText.Outline = true
            dText.Center = true
            dText.Visible = true
            dText.Color = color
            dText.Text = tostring(dist) .. "m"
            dText.Position = Vector2.new(rootPos.X, (espDrawings[player.Name .. "_Name"] and espDrawings[player.Name .. "_Name"].Position.Y + 15) or (rootPos.Y - 30))
            espDrawings[player.Name .. "_Distance"] = dText
        end
    end
end

RunService.RenderStepped:Connect(function()
    fovCircle.Position = UDim2.new(0.5, 0, 0.5, 0)
    
    if AutoAim then
        local t = getTarget()
        if t and t.Character and t.Character:FindFirstChild(AimPart) then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, t.Character[AimPart].Position)
        end
    end
    
    if ESP_Enabled or Tracer_Enabled or DistanceESP_Enabled then
        for _, drawing in pairs(espDrawings) do 
            drawing.Visible = false 
        end
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LP and not isSameTeam(player) and player.Character then
                drawVisuals(player, Color3.fromRGB(255, 0, 0))
            end
        end
    end
end)
